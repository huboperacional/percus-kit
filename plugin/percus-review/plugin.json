{
  "name": "percus-review",
  "version": "5.0.2",
  "description": "Review cross-provider Percus (DeepSeek + Cross-Claude) + skills/hooks de adoção (Fase 5). v5.0.2: corrige schema de hooks no manifest + PS 5.1 compat (BOM, UTF-8, git stderr guard).",
  "author": { "name": "Percus" },
  "commands": "./commands",
  "scripts": "./scripts",
  "skills": "./skills",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-check.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-stop-check.ps1"
          }
        ]
      }
    ]
  }
}
