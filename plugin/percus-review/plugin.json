{
  "name": "percus-review",
  "version": "5.0.0",
  "description": "Review cross-provider Percus (DeepSeek + Cross-Claude) + skills/hooks de adoção (Fase 5)",
  "author": { "name": "Percus" },
  "commands": "./commands",
  "scripts": "./scripts",
  "skills": "./skills",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-check.ps1"
      }
    ],
    "Stop": [
      {
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-stop-check.ps1"
      }
    ]
  }
}
